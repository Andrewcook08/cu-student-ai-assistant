# Host-side overrides (localhost instead of Docker-internal hostnames)
# Copy to .env.local — it is gitignored and will override .env values.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cu_assistant
NEO4J_URI=bolt://localhost:7687
REDIS_URL=redis://localhost:6379/0
OLLAMA_URL=http://localhost:11434
